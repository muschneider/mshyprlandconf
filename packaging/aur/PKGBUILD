# Maintainer: hyprconf contributors <noreply@github.com>
pkgname=hyprconf
pkgver=1.0.0
pkgrel=1
pkgdesc="Desktop GUI for editing the full surface of Hyprland configuration (Lua & conf)"
arch=('x86_64' 'aarch64')
url="https://github.com/hyprconf/hyprconf"
license=('MIT' 'Apache-2.0')
depends=('libxkbcommon' 'wayland' 'vulkan-icd-loader')
makedepends=('rust' 'cargo')
optdepends=('hyprland: live-apply and reload via hyprctl')
options=('!lto') # the workspace release profile already enables LTO
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP') # replace with the real checksum when tagging a release

prepare() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --frozen --release -p hyprconf-gui
}

check() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  cargo test --frozen --release --workspace
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm0755 "target/release/hyprconf" "$pkgdir/usr/bin/hyprconf"
  install -Dm0644 packaging/hyprconf.desktop "$pkgdir/usr/share/applications/hyprconf.desktop"
  install -Dm0644 LICENSE-MIT "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
  install -Dm0644 LICENSE-APACHE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-APACHE"
  install -Dm0644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
